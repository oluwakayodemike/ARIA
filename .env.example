# ARIA demo mode - this is a simplified mode for demo purposes that simulates interactions without needing a live Splunk instance. Set ARIA_DEMO_MODE=false to use live Splunk mode instead.
ARIA_DEMO_MODE=true
ARIA_DEMO_FIXTURE_PATH=scripts/demo_state.json
ARIA_DEMO_SIMULATE_RUN_SEC=12

# live Splunk mode. set ARIA_DEMO_MODE=false before using these.
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=replace-with-your-splunk-password

# Splunk MCP / AI Assistant integration.
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=replace-with-your-splunk-mcp-token
SPLUNK_MCP_VERIFY_SSL=false
SPLUNK_MCP_TIMEOUT_SEC=30
SPLUNK_AI_PRIMARY=true

SPLUNK_MCP_TOOL_GENERATE=saia_generate_spl
SPLUNK_MCP_TOOL_OPTIMIZE=saia_optimize_spl
SPLUNK_MCP_TOOL_EXPLAIN=saia_explain_spl

# optional: fallback when Splunk MCP generation is unavailable.
GEMINI_API_KEY=replace-with-your-gemini-api-key
